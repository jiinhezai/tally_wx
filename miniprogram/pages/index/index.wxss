/* pages/index/index.wxss */
.page-container {
  min-height: 100vh;
  /* 科技感清爽渐变背景 */
  background: linear-gradient(180deg, #E3F2FD 0%, #F8FAFC 100%);
  padding: 40rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 顶部区域 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10%;
  margin-bottom: 60rpx;
}

.header .title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
}

.history-btn {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666666;
  background: #ffffff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 用户信息卡片 */
.profile-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: transparent;
  position: relative;
  overflow: visible; /* 允许角标溢出 */
}

.avatar-btn::after {
  border: none; /* 移除小程序button自带的边框 */
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 相机小角标 */
.camera-badge {
  position: absolute;
  bottom: 0;
  right: -10rpx;
  background: #4facfe;
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 4rpx solid #ffffff;
}

.nickname-box {
  margin-top: 40rpx;
  display: flex;
  align-items: center;
  background: #f7f8fa;
  padding: 20rpx 40rpx;
  border-radius: 100rpx;
  width: 80%;
  box-sizing: border-box;
}

.nickname-input {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.profile-card .tips {
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 按钮区域 */
.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx; /* 按钮之间的间距 */
}

.action-btn {
  font-size: 32rpx !important;
  font-weight: bold !important;
  border-radius: 20rpx !important; /* 让圆角稍微方正一点，更显现代 */
  height: 100rpx !important;
}

.main-btn {
  box-shadow: 0 8rpx 24rpx rgba(79, 172, 254, 0.3);
}

.scan-btn {
  background: #ffffff !important; /* 扫码按钮底色纯白 */
}

/* 底部提示 */
.footer-notice {
  margin-top: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  color: #ee0a24;
  background: #fff0f0;
  padding: 16rpx 30rpx;
  border-radius: 100rpx;
}